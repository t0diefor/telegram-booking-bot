# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Random secret used to verify inbound webhook requests actually came from Telegram.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-random-string

# BOT_MODE: "polling" for local dev, "webhook" for production
BOT_MODE=polling

# Only needed when BOT_MODE=webhook. Must be a public HTTPS URL Telegram can reach.
WEBHOOK_URL=https://your-domain.example.com/webhook
WEBHOOK_LISTEN_HOST=0.0.0.0
WEBHOOK_LISTEN_PORT=8443

# --- OpenClaw Gateway (LLM backend) ---
# The OpenAI-compatible endpoint must be enabled on the Gateway first:
#   gateway.http.endpoints.chatCompletions.enabled = true
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
# "openclaw/default" or "openclaw/<agentId>" - see README for routing to a specific agent
OPENCLAW_AGENT_MODEL=openclaw/default

# --- Database ---
DB_PATH=./data/bot.db
CONVERSATION_HISTORY_MAX_AGE_DAYS=30

# --- Logging ---
LOG_PATH=./logs/bot.log
LOG_LEVEL=INFO
